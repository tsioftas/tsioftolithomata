<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title id="τίτλος">Explore the collection</title>
    <meta name="description" content="{{ meta_description }}">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="stylesheet" href="{{ root_relative_prefix }}style.css">
    <link rel="icon" href="{{root_relative_prefix}}favicon.ico" type="image/x-icon">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="{{ root_relative_prefix }}scripts/explore.css">
</head>
<body>
    <div id="header-container"></div>

    <main>
        <div class="main-section-wrapper">
            <section id="explore-page">
                <!-- Filter bar -->
                <div id="explore-filters">
                    <div class="filter-row">
                        <span class="filter-label" id="filter-country-label"></span>
                        <div class="pill-group" id="country-pills"></div>
                    </div>

                    <div class="filter-row">
                        <span class="filter-label" id="filter-taxon-label"></span>
                        <div class="pill-group" id="major-taxa-pills"></div>
                    </div>

                    <div class="filter-row">
                        <div class="search-wrapper">
                            <input type="text" id="taxon-search" autocomplete="off" />
                            <div id="taxon-search-results" class="search-results"></div>
                        </div>
                        <button type="button" id="filter-clear-all"></button>
                        <div id="selected-taxa-chips" class="chip-group"></div>
                    </div>
                </div>

                <!-- Map -->
                <div id="map" style="z-index: 1;"></div>

                <!-- Timeline -->
                <div id="timeline-wrapper">
                    <div id="timeline-handle-labels"></div>
                    <svg id="timeline-svg" preserveAspectRatio="none"></svg>
                    <div id="timeline-handles">
                        <div id="handle-older" class="timeline-handle" title=""><span></span></div>
                        <div id="handle-newer" class="timeline-handle" title=""><span></span></div>
                    </div>
                </div>
            </section>
        </div>
    </main>

    <div id="footer-container"></div>

    <!-- Cookie banner (translated by language.js) -->
    <div id="cookie-banner" style="display:none; position:fixed; bottom:0; left:0; right:0; background:#222; color:#fff; padding:1em; z-index:9999; font-size:14px; text-align:center;">
        <a id="cookie-banner-text">This site uses cookies to analyze traffic.</a>
        <button onclick="setConsent(true)" style="margin-left:1em;" id="cookie-banner-accept">Accept</button>
        <button onclick="setConsent(false)" style="margin-left:0.5em;" id="cookie-banner-decline">Decline</button>
    </div>

    <!-- Inline data for explore.js (server-rendered) -->
    <script>
        window.LOCALITIES = {{ localities_dataset | safe }};
        window.TAXA_INDEX = {{ taxa_index | safe }};
        window.MAJOR_TAXA = {{ major_taxa | safe }};
        window.ICS_PERIODS = {{ ics_periods | safe }};
        window.COUNTRIES = {{ countries | safe }};
        window.TAXON_ICON_URLS = {{ taxon_icons | safe }};
        window.ROOT_PREFIX = "{{ root_relative_prefix }}";
    </script>

    <!-- Translation/language framework -->
    <script
        id="language-script"
        src="{{ root_relative_prefix }}scripts/language.js"
        dict="/map.json"
        keys="τίτλος,filter-country-label,filter-taxon-label,filter-clear-all"
        galleryLength="0"
    ></script>

    <!-- Leaflet -->
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha384-cxOPjt7s7Iz04uaHJceBmS+qpjv2JkIHNVcuOrM+YHwZOmJGBXI00mdUXEq65HTH" crossorigin="anonymous"></script>

    <!-- Explore page logic -->
    <script src="{{ root_relative_prefix }}scripts/explore.js"></script>

    <!-- Header chrome (loaded after language.js so getBaseURL, waitForCondition, getLanguage, _LANGUAGES, navPath are in scope) -->
    <script src="{{ root_relative_prefix }}scripts/sidebar.js"></script>
    <script src="{{ root_relative_prefix }}scripts/search.js"></script>
    <script src="{{ root_relative_prefix }}scripts/analytics.js"></script>
    <script src="{{ root_relative_prefix }}scripts/footer.js"></script>
    <script src="{{ root_relative_prefix }}scripts/header.js"></script>
</body>
</html>
