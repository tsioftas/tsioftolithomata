<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="{{meta_description}}">
    {% if meta_keywords -%}
    <meta name="keywords" content="{{meta_keywords}}">
    {% endif -%}
    <meta property="og:type" content="website">
    <meta property="og:title" content="{{name_en.capitalize()}}">
    <meta property="og:description" content="{{meta_description}}">
    <meta property="og:url" content="{{page_url}}">
    <meta property="og:image" content="{{og_image}}">
    <meta name="twitter:card" content="summary_large_image">
    <title id="τίτλος">{{name_en.capitalize()}}</title>
    <link rel="icon" href="{{root_relative_prefix}}favicon.ico" type="image/x-icon">
    <link rel="stylesheet" href="{{root_relative_prefix}}style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/lightgallery/2.7.2/css/lightgallery.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/lightgallery/2.7.2/css/lg-zoom.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=GFS+Didot&family=Cormorant+Garamond:wght@500;600&display=swap">
</head>
<body>
    <div id="header-container"></div>

    <div class="main-section-wrapper">
        <main>
            <section class="taxon-hero" id="{{taxon_id}}-hero">
                <h2 id="{{taxon_id}}"></h2>
            </section>

            {% set galleryns=namespace(img_counter=0, gallery_counter=0) -%}
            {% if samples_by_locality -%}
            <section class="taxon-fossils" id="{{taxon_id}}-gallery">
                {% for locality, samples in samples_by_locality.items() %}
                {% set lmeta = locality_meta.get(locality, {}) -%}
                {% set preview_img = samples[0].preview_images[0] if samples and samples[0].preview_images else None -%}
                <details class="locality-block">
                    <summary class="locality-header">
                        <div class="locality-meta">
                            {% if lmeta.has_age -%}
                            <span class="locality-age-badge" id="loc-{{locality}}-age"></span>
                            {% endif -%}
                            {% if lmeta.has_formation -%}
                            <span class="locality-formation" id="loc-{{locality}}-formation"></span>
                            {% endif -%}
                            {% if lmeta.flag_emoji -%}
                            <span class="locality-flag" title="{{lmeta.country|upper}}">{{lmeta.flag_emoji}}</span>
                            {% endif -%}
                        </div>
                        <div class="locality-header-row">
                            {% if preview_img -%}
                            <picture class="locality-preview">
                                <source srcset="{{root_relative_prefix}}{{preview_img.images_dir}}/thumbs_dir/{{preview_img.filename}}_thumb.webp 1x" type="image/webp">
                                <img loading="lazy" src="{{root_relative_prefix}}{{preview_img.images_dir}}/thumbs_dir/{{preview_img.filename}}_thumb.jpg" alt="">
                            </picture>
                            {% endif -%}
                            <div class="locality-titlewrap">
                                <a class="locality-name-link" href="{{root_relative_prefix}}localities/{{locality}}.html" onclick="event.stopPropagation();">
                                    <h3 class="locality-name" id="loc-{{locality}}-name"></h3>
                                </a>
                                <span class="locality-count">🦴 {{samples|length}}</span>
                            </div>
                            <span class="locality-toggle" aria-hidden="true">+</span>
                        </div>
                    </summary>
                    <div class="gallery" id="gallery-{{locality}}">
                        {% for sample in samples %}
                        {% set galleryns.gallery_counter = galleryns.gallery_counter + 1 %}
                        {% set preview_images = sample.preview_images %}
                        <div class="sample-box" id="sample-{{ sample.sample_id }}" onclick="openGallery({{ galleryns.gallery_counter }})">
                            {% if preview_images|length == 1 %}
                            <picture class="image-single">
                                <source srcset="{{root_relative_prefix}}{{preview_images[0].images_dir}}/thumbs_dir/{{preview_images[0].filename}}_thumb.webp 1x" type="image/webp">
                                <img loading="lazy" src="{{root_relative_prefix}}{{preview_images[0].images_dir}}/thumbs_dir/{{preview_images[0].filename}}_thumb.jpg" alt="{{preview_images[0].caption.en}}">
                            </picture>
                            {% elif preview_images|length == 2 %}
                            <div class="image-two">
                                <picture class="image-main">
                                    <source srcset="{{root_relative_prefix}}{{preview_images[0].images_dir}}/thumbs_dir/{{preview_images[0].filename}}_thumb.webp 1x" type="image/webp">
                                    <img loading="lazy" src="{{root_relative_prefix}}{{preview_images[0].images_dir}}/thumbs_dir/{{preview_images[0].filename}}_thumb.jpg" alt="{{preview_images[0].caption.en}}">
                                </picture>
                                <div class="image-overlay">+1</div>
                            </div>
                            {% else %}
                            <div class="image-three">
                                <div class="image-left">
                                    <picture>
                                        <source srcset="{{root_relative_prefix}}{{preview_images[0].images_dir}}/thumbs_dir/{{preview_images[0].filename}}_thumb.webp 1x" type="image/webp">
                                        <img loading="lazy" src="{{root_relative_prefix}}{{preview_images[0].images_dir}}/thumbs_dir/{{preview_images[0].filename}}_thumb.jpg" alt="{{preview_images[0].caption.en}}">
                                    </picture>
                                </div>
                                <div class="image-right">
                                    <div class="image-top-right">
                                        <picture>
                                            <source srcset="{{root_relative_prefix}}{{preview_images[1].images_dir}}/thumbs_dir/{{preview_images[1].filename}}_thumb.webp 1x" type="image/webp">
                                            <img loading="lazy" src="{{root_relative_prefix}}{{preview_images[1].images_dir}}/thumbs_dir/{{preview_images[1].filename}}_thumb.jpg" alt="{{preview_images[1].caption.en}}">
                                        </picture>
                                    </div>
                                    <div class="image-bottom-right">
                                        <picture>
                                            <source srcset="{{root_relative_prefix}}{{preview_images[2].images_dir}}/thumbs_dir/{{preview_images[2].filename}}_thumb.webp 1x" type="image/webp">
                                            <img loading="lazy" src="{{root_relative_prefix}}{{preview_images[2].images_dir}}/thumbs_dir/{{preview_images[2].filename}}_thumb.jpg" alt="{{preview_images[2].caption.en}}">
                                        </picture>
                                        {% if preview_images|length > 3 %}
                                        <div class="image-overlay">+{{ preview_images|length - 3 }}</div>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                            {% endif %}

                            {% if sample.acquisition == 'purchased' %}
                            <span class="purchased-badge">
                                <svg class="purchased-badge-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M2 12 12 2h8v8L10 20z"/><circle cx="16.5" cy="7.5" r="1.5"/></svg>
                                <span class="purchased-badge-label"></span>
                            </span>
                            {% endif %}

                            <!-- Hidden gallery -->
                            <div id="hidden-gallery-{{ galleryns.gallery_counter }}" data-sample-id="{{ sample.sample_id }}" style="display: none;">
                                {% for img in sample.display_images %}
                                {% set galleryns.img_counter = galleryns.img_counter + 1 %}
                                <a href="{{root_relative_prefix}}{{img.images_dir}}/{{img.filename}}.jpg" id="gallery-img-{{galleryns.img_counter}}">
                                    <picture>
                                        <source srcset="{{root_relative_prefix}}{{img.images_dir}}/thumbs_dir/{{img.filename}}_thumb.webp 1x" type="image/webp">
                                        <img loading="lazy" src="{{root_relative_prefix}}{{img.images_dir}}/thumbs_dir/{{img.filename}}_thumb.jpg" alt="{{img.caption.en}}">
                                    </picture>
                                </a>
                                {% endfor %}
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                </details>
                {% endfor %}
            </section>
            {% endif -%}

            <section class="taxon-story" id="{{taxon_id}}-story">
                <div class="story-visuals">
                    <picture class="story-illustration">
                        <source srcset="{{root_relative_prefix}}images/thumbnails/webp_dir/{{name_el.capitalize() | urlencode}}.webp 1x" type="image/webp">
                        <img loading="lazy" src="{{root_relative_prefix}}images/thumbnails/{{name_el.capitalize()}}.jpg" alt="{{name_en}}" class="tax-page-image" id="{{taxon_id}}-περιγραφή-1-εικόνα">
                    </picture>
                    {% if taxon_icon -%}
                    <div class="story-phylopic">
                        <img src="{{ taxon_icon }}" alt="" loading="lazy">
                    </div>
                    {% endif -%}
                </div>
                <div class="story-text">
                    <div class="story-main">
                        <div class="description-text">
                            {% for i in range(description_paragraphs) %}<p id="{{taxon_id}}-περιγραφή-{{i+1}}"></p>
                            {% endfor %}
                        </div>
                    </div>
                    {% if etymology_paragraphs > 0 -%}
                    <aside class="story-aside">
                        <h3 class="story-eyebrow" id="ετυμολογία"></h3>
                        <div class="etymology-text">
                            {% for i in range(etymology_paragraphs) %}<p id="{{taxon_id}}-ετυμολογία-{{i+1}}"></p>
                            {% endfor %}
                        </div>
                    </aside>
                    {% endif -%}
                </div>
            </section>

            {% if subtaxa -%}
            <section class="taxon-sub" id="{{taxon_id}}-sub">
                <h3 class="story-eyebrow" id="υποομάδες"></h3>
                <div class="subtaxa-grid">
                    {% for subtaxon_id, subtaxon_dict in subtaxa.items() -%}
                    {% set smeta = subtaxa_meta.get(subtaxon_id, {}) -%}
                    <a class="subtaxa-card{% if smeta.extinct %} subtaxa-card-extinct{% endif %}" href="{{subtaxon_id}}/{{subtaxon_id}}.html">
                        <picture>
                            <source srcset="{{root_relative_prefix}}images/thumbnails/thumbs_dir/{{subtaxon_dict.name.el.capitalize() | urlencode}}_thumb.webp 1x" type="image/webp">
                            <img loading="lazy" src="{{root_relative_prefix}}images/thumbnails/thumbs_dir/{{subtaxon_dict.name.el.capitalize()}}_thumb.jpg" alt="{{subtaxon_dict.name.en}}" class="tax-thumbnail-image">
                        </picture>
                        <h4 class="subtaxa-card-name" id="{{taxon_id}}-{{subtaxon_id}}"></h4>
                        <div class="subtaxa-card-meta">
                            {% if smeta.rank -%}
                            <span class="subtaxa-card-rank" id="subtaxa-{{subtaxon_id}}-rank"></span>
                            {% endif -%}
                            {% if smeta.sample_count > 0 -%}
                            <span class="subtaxa-card-count" title="{{smeta.sample_count}} samples">🦴 {{smeta.sample_count}}</span>
                            {% endif -%}
                        </div>
                    </a>
                    {% endfor -%}
                </div>
            </section>{% endif %}
        </main>
    </div>

    <div id="footer-container"></div>

    <script 
        id="language-script"
        src="{{root_relative_prefix}}scripts/language.js"
        dict="{{dir}}/{{taxon_id}}.json"
        keys="τίτλος,{{taxon_id}}{% for i in range(description_paragraphs) %},{{taxon_id}}-περιγραφή-{{i+1}}{% endfor %}{% if etymology_paragraphs > 0 %},ετυμολογία{% for i in range(etymology_paragraphs) %},{{taxon_id}}-ετυμολογία-{{i+1}}{% endfor %}{% endif %}{% if samples_by_locality %}{% for locality in samples_by_locality.keys() %},loc-{{locality}}-name{% if locality_meta.get(locality, {}).get('has_age') %},loc-{{locality}}-age{% endif %}{% if locality_meta.get(locality, {}).get('has_formation') %},loc-{{locality}}-formation{% endif %}{% endfor %}{% endif %}{% if subtaxa %},υποομάδες{% for subtaxon_id in subtaxa.keys() %},{{taxon_id}}-{{subtaxon_id}}{% if subtaxa_meta.get(subtaxon_id, {}).get('rank') %},subtaxa-{{subtaxon_id}}-rank{% endif %}{% endfor %}{% endif %}"
        galleryLength="{{galleryns.img_counter}}"
    ></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/lightgallery/2.7.2/lightgallery.min.js" integrity="sha384-MjUNxSaHL/6eoaiJXs3NcsYt5PMcFos3RjoGKaBj8wqEu0lYAn0HISvhdiF8fjec" crossorigin="anonymous"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/lightgallery/2.7.2/plugins/zoom/lg-zoom.min.js" integrity="sha384-iqgECBkmcDeuB5f3eHKQ6uwRVFs6/4auvPpRhMS/KjpIuzgmo2W17KoMh8iGyAHy" crossorigin="anonymous"></script>
    <script>
        function openGallery(index, imgIndex) {
            const elem = document.getElementById("hidden-gallery-" + index);
            // Build the lightGallery instance once per specimen and reuse it on
            // subsequent opens, so closed lightboxes don't pile up in the DOM.
            if (!elem._lgInstance) {
                const items = Array.from(elem.querySelectorAll('a')).map(a => ({
                    src: a.href,
                    thumb: a.querySelector('img')?.src,
                    subHtml: a.getAttribute('data-sub-html') || '@@@@'
                }));
                elem._lgInstance = lightGallery(elem, {
                    dynamic: true,
                    plugins: [lgZoom],
                    thumbnail: true,
                    loop: true,
                    dynamicEl: items
                });
                attachLightboxShare(elem, elem.dataset.sampleId);
            }
            elem._lgInstance.openGallery(imgIndex || 0);
        }
    </script>

    <script src="{{root_relative_prefix}}scripts/sidebar.js"></script>
    <script src="{{root_relative_prefix}}scripts/search.js"></script>
    <script src="{{root_relative_prefix}}scripts/analytics.js"></script>
    <script src="{{root_relative_prefix}}scripts/footer.js"></script>
    <script src="{{root_relative_prefix}}scripts/share.js"></script>
    <script src="{{root_relative_prefix}}scripts/tts.js"></script>
    <script src="{{root_relative_prefix}}scripts/header.js" id="header-script"></script>
    
    <div id="cookie-banner" style="display:none; position:fixed; bottom:0; left:0; right:0; background:#222; color:#fff; padding:1em; z-index:9999; font-size:14px; text-align:center;">
        <a id="cookie-banner-text">This site uses cookies to analyze traffic.</a>
        <button onclick="setConsent(true)" style="margin-left:1em;" id="cookie-banner-accept">Accept</button>
        <button onclick="setConsent(false)" style="margin-left:0.5em;" id="cookie-banner-decline">Decline</button>
    </div>
</body>
</html>
