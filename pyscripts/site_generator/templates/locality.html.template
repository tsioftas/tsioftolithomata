<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="{{meta_description}}">
    {% if meta_keywords -%}
    <meta name="keywords" content="{{meta_keywords}}">
    {% endif -%}
    <meta property="og:type" content="website">
    <meta property="og:title" content="{{name_en.capitalize()}}">
    <meta property="og:description" content="{{meta_description}}">
    <meta property="og:url" content="{{page_url}}">
    <meta property="og:image" content="{{og_image}}">
    <meta name="twitter:card" content="summary_large_image">
    <title id="τίτλος">{{name_en.capitalize()}}</title>
    <link rel="icon" href="{{root_relative_prefix}}favicon.ico" type="image/x-icon">
    <link rel="stylesheet" href="{{root_relative_prefix}}style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/lightgallery/2.7.2/css/lightgallery.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/lightgallery/2.7.2/css/lg-zoom.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=GFS+Didot&family=Cormorant+Garamond:wght@500;600&display=swap">
</head>
<body>
    <div id="header-container"></div>

    <div class="main-section-wrapper">
        <main>
            <section class="taxon-hero" id="{{loc_id}}-hero">
                <h2 id="{{loc_id}}"></h2>
            </section>

            <section id="{{loc_id}}-description">
                <div class="tax-subcontainer">
                    <div class="locality-figure">
                        <picture>
                            <source srcset="{{root_relative_prefix}}images/localities/thumbnails/webp_dir/{{loc_id}}.webp 1x" type="image/webp">
                            <img loading="lazy" src="{{root_relative_prefix}}images/localities/thumbnails/{{loc_id}}.jpg" alt="{{name_en}}" class="tax-page-image" id="{{loc_id}}-περιγραφή-1-εικόνα">
                        </picture>
                        {% if loc.formation is defined -%}
                        <a class="locality-globe" href="{{root_relative_prefix}}map.html?locality={{loc_id}}" title="{{name_en}} on the map">
                            <picture>
                                <source srcset="{{root_relative_prefix}}images/localities/globe/webp_dir/{{loc_id}}.webp 1x" type="image/webp">
                                <img loading="lazy" src="{{root_relative_prefix}}images/localities/globe/{{loc_id}}.jpg" alt="{{name_en}} shown on the globe" id="{{loc_id}}-γη-εικόνα">
                            </picture>
                        </a>
                        {% endif -%}
                    </div>
                    {% if loc.formation is defined -%}
                    <div class="side-by-side-container">
                        <ul>
                            <li>
                                <b><a id="age-label"></a>:</b> <a id="{{loc_id}}-age">{% if loc.age.from is defined %}{{loc.age.from}}-{{loc.age.to}}{% else %}~{{loc.age.about}}{% endif %} <a id="mya"></a></a>
                            </li>
                            <li>
                                <b><a id="period-label"></a>:</b> <a>{% if loc.age.prefix is defined %}<a id="{{loc.age.prefix}}"></a> {% endif %}<a id="{{loc.age.period}}"></a>{% if loc.age.period_detail is defined %} (<a id="{{loc.age.period_detail}}"></a>){% endif %}</a>
                            </li>
                            <li>
                                <b><a id="formation-label"></a>:</b> <a id="{{loc_id}}-formation">{{loc.formation.en}}</a>
                            </li>
                            <li>
                                <b><a id="depositional_environment-label"></a>:</b> <a id="{{loc_id}}-depositional_environment">{{loc.depositional_environment.en}}</a>
                            </li>
                            <li>
                                <b><a id="fossil_types-label"></a>:</b> <a id="{{loc_id}}-fossil_types">{{loc.fossil_types.en}}</a>
                            </li>
                            <li>
                                <b><a id="paleoecology_highlights-label"></a>:</b> <a id="{{loc_id}}-paleoecology_highlights">{{loc.paleoecology_highlights.en}}</a>
                            </li>
                        </ul>
                    </div>
                    {% endif -%}
                    <div class="description-text">
                        {% for i in range(description_paragraphs) %}<p id="{{loc_id}}-περιγραφή-{{i+1}}"></p>
                        {% endfor %}
                    </div>
                    {% if loc_id == "chapel-st-leonards" %}
                    <picture>
                        <source srcset="{{root_relative_prefix}}images/localities/webp_dir/longshore-drift.webp 1x" type="image/webp">
                        <img loading="lazy" src="{{root_relative_prefix}}images/localities/longshore-drift.jpg" alt="how longshore drift transported fossils at Chapel St Leonards" id="longshore-drift-εικόνα">
                    </picture>
                    <p id="longshore-drift-description"></p>
                    {% endif %}
                </div>
            </section>

            {% set galleryns=namespace(img_counter=0, gallery_counter=0) -%}
            <section class="taxon-fossils" id="{{loc_id}}-galleries">
            {% for taxon_id, taxon_info in locality_taxonomy_info -%}
            {% if taxon_id in samples_by_taxon -%}
                <details class="locality-block">
                    <summary class="locality-header">
                        <div class="locality-header-row">
                            <picture class="locality-preview">
                                <source srcset="{{root_relative_prefix}}images/thumbnails/webp_dir/{{taxon_info["name"]["el"].capitalize() | urlencode}}.webp 1x" type="image/webp">
                                <img loading="lazy" src="{{root_relative_prefix}}images/thumbnails/{{taxon_info["name"]["el"].capitalize()}}.jpg" alt="Artistic depiction of {{taxon_info["name"]["en"].capitalize()}}">
                            </picture>
                            <div class="locality-titlewrap">
                                <a class="locality-name-link" href="{{root_relative_prefix}}{{taxon_info["path"]}}" onclick="event.stopPropagation();">
                                    <h3 class="locality-name" id="{{loc_id}}-{{taxon_id}}"></h3>
                                </a>
                                <span class="locality-count">🦴 {{ samples_by_taxon[taxon_id]|length }}</span>
                            </div>
                            <span class="locality-toggle" aria-hidden="true">+</span>
                        </div>
                    </summary>
                    <div class="gallery" id="gallery-{{taxon_id}}">
                            {% for sample in samples_by_taxon[taxon_id] %}
                            {% set galleryns.gallery_counter = galleryns.gallery_counter + 1 %}
                            {% set display_images = sample.display_images %}
                                <div class="sample-box" id="sample-{{ sample.sample_id }}" onclick="openGallery({{ galleryns.gallery_counter }})">
                                    {% if display_images|length == 1 %}
                                    <picture class="image-single">
                                        <source srcset="{{root_relative_prefix}}{{display_images[0].images_dir}}/thumbs_dir/{{display_images[0].filename}}_thumb.webp 1x" type="image/webp">
                                        <img loading="lazy" src="{{root_relative_prefix}}{{display_images[0].images_dir}}/thumbs_dir/{{display_images[0].filename}}_thumb.jpg" alt="{{display_images[0].caption.en}}">
                                    </picture>
                                    {% elif display_images|length == 2 %}
                                    <div class="image-two">
                                        <picture class="image-main">
                                            <source srcset="{{root_relative_prefix}}{{display_images[0].images_dir}}/thumbs_dir/{{display_images[0].filename}}_thumb.webp 1x" type="image/webp">
                                            <img loading="lazy" src="{{root_relative_prefix}}{{display_images[0].images_dir}}/thumbs_dir/{{display_images[0].filename}}_thumb.jpg" alt="{{display_images[0].caption.en}}">
                                        </picture>
                                        <div class="image-overlay">+1</div>
                                    </div>
                                    {% else %}
                                    <div class="image-three">
                                        <div class="image-left">
                                            <picture>
                                                <source srcset="{{root_relative_prefix}}{{display_images[0].images_dir}}/thumbs_dir/{{display_images[0].filename}}_thumb.webp 1x" type="image/webp">
                                                <img loading="lazy" src="{{root_relative_prefix}}{{display_images[0].images_dir}}/thumbs_dir/{{display_images[0].filename}}_thumb.jpg" alt="{{display_images[0].caption.en}}">
                                            </picture>
                                        </div>
                                        <div class="image-right">
                                            <div class="image-top-right">
                                                <picture>
                                                    <source srcset="{{root_relative_prefix}}{{display_images[1].images_dir}}/thumbs_dir/{{display_images[1].filename}}_thumb.webp 1x" type="image/webp">
                                                    <img loading="lazy" src="{{root_relative_prefix}}{{display_images[1].images_dir}}/thumbs_dir/{{display_images[1].filename}}_thumb.jpg" alt="{{display_images[1].caption.en}}">
                                                </picture>
                                            </div>
                                            <div class="image-bottom-right">
                                                <picture>
                                                    <source srcset="{{root_relative_prefix}}{{display_images[2].images_dir}}/thumbs_dir/{{display_images[2].filename}}_thumb.webp 1x" type="image/webp">
                                                    <img loading="lazy" src="{{root_relative_prefix}}{{display_images[2].images_dir}}/thumbs_dir/{{display_images[2].filename}}_thumb.jpg" alt="{{display_images[2].caption.en}}">
                                                </picture>
                                                {% if display_images|length > 3 %}
                                                <div class="image-overlay">+{{ display_images|length - 3 }}</div>
                                                {% endif %}
                                            </div>
                                        </div>
                                    </div>
                                    {% endif %}

                                    <!-- Hidden gallery -->
                                    <div id="hidden-gallery-{{ galleryns.gallery_counter }}" data-sample-id="{{ sample.sample_id }}" style="display: none;">
                                        {% for img in display_images %}
                                        {% set galleryns.img_counter = galleryns.img_counter + 1 %}
                                        <a href="{{root_relative_prefix}}{{img.images_dir}}/{{img.filename}}.jpg" id="gallery-img-{{galleryns.img_counter}}">
                                            <picture>
                                                <source srcset="{{root_relative_prefix}}{{img.images_dir}}/thumbs_dir/{{img.filename}}_thumb.webp 1x" type="image/webp">
                                                <img loading="lazy" src="{{root_relative_prefix}}{{img.images_dir}}/thumbs_dir/{{img.filename}}_thumb.jpg" alt="{{img.caption.en}}">
                                            </picture>
                                        </a>
                                        {% endfor %}
                                    </div>
                                </div>
                            {% endfor %}
                    </div>
                </details>
                {% endif -%}
            {% endfor -%}
            </section>
        </main>
    </div>

    <div id="footer-container"></div>

    <script 
        id="language-script"
        src="{{root_relative_prefix}}scripts/language.js"
        dict="{{dir}}/{{loc_id}}.json"
        keys="τίτλος,{{loc_id}}{% for i in range(description_paragraphs) %},{{loc_id}}-περιγραφή-{{i+1}}{% endfor %},age-label,period-label,formation-label,depositional_environment-label,fossil_types-label,paleoecology_highlights-label,{{loc_id}}-formation,{{loc_id}}-depositional_environment,{{loc_id}}-fossil_types,{{loc_id}}-paleoecology_highlights,{% if loc.age.prefix is defined %}{{loc.age.prefix}},{% endif %}{{loc.age.period}},{% if loc.age.period_detail is defined %}{{loc.age.period_detail}},{% endif %}{% for taxon_id in samples_by_taxon.keys() -%}{{loc_id}}-{{taxon_id}},{% endfor %}{% if loc_id == "chapel-st-leonards" %}longshore-drift-description,{% endif %}mya"
        galleryLength="{{galleryns.img_counter}}"
    ></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/lightgallery/2.7.2/lightgallery.min.js" integrity="sha384-MjUNxSaHL/6eoaiJXs3NcsYt5PMcFos3RjoGKaBj8wqEu0lYAn0HISvhdiF8fjec" crossorigin="anonymous"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/lightgallery/2.7.2/plugins/zoom/lg-zoom.min.js" integrity="sha384-iqgECBkmcDeuB5f3eHKQ6uwRVFs6/4auvPpRhMS/KjpIuzgmo2W17KoMh8iGyAHy" crossorigin="anonymous"></script>
    <script>
        function openGallery(index, imgIndex) {
            const elem = document.getElementById("hidden-gallery-" + index);
            // Build the lightGallery instance once per specimen and reuse it on
            // subsequent opens, so closed lightboxes don't pile up in the DOM.
            if (!elem._lgInstance) {
                const items = Array.from(elem.querySelectorAll('a')).map(a => ({
                    src: a.href,
                    thumb: a.querySelector('img')?.src,
                    subHtml: a.getAttribute('data-sub-html') || '@@@@'
                }));
                elem._lgInstance = lightGallery(elem, {
                    dynamic: true,
                    plugins: [lgZoom],
                    thumbnail: true,
                    loop: true,
                    dynamicEl: items
                });
                attachLightboxShare(elem, elem.dataset.sampleId);
            }
            elem._lgInstance.openGallery(imgIndex || 0);
        }
    </script>

    <script src="{{root_relative_prefix}}scripts/sidebar.js"></script>
    <script src="{{root_relative_prefix}}scripts/search.js"></script>
    <script src="{{root_relative_prefix}}scripts/analytics.js"></script>
    <script src="{{root_relative_prefix}}scripts/footer.js"></script>
    <script src="{{root_relative_prefix}}scripts/share.js"></script>
    <script src="{{root_relative_prefix}}scripts/tts.js"></script>
    <script src="{{root_relative_prefix}}scripts/header.js" id="header-script"></script>

    <div id="cookie-banner" style="display:none; position:fixed; bottom:0; left:0; right:0; background:#222; color:#fff; padding:1em; z-index:9999; font-size:14px; text-align:center;">
        <a id="cookie-banner-text">This site uses cookies to analyze traffic.</a>
        <button onclick="setConsent(true)" style="margin-left:1em;" id="cookie-banner-accept">Accept</button>
        <button onclick="setConsent(false)" style="margin-left:0.5em;" id="cookie-banner-decline">Decline</button>
    </div>
</body>
</html>
