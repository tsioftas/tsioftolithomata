<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Test your knowledge of the fossil collection: identify taxa from silhouettes, guess geological periods and localities, find closest relatives.">
    <title id="quiz-title">Quiz</title>
    <link rel="icon" href="favicon.ico" type="image/x-icon">
    <link rel="stylesheet" href="./style.css">
</head>
<body>
    <div id="header-container"></div>

    <div class="main-section-wrapper">
        <main>
            <section class="quiz-page">

                <div id="quiz-intro-screen" class="quiz-card">
                    <h1 id="quiz-page-heading"></h1>
                    <p id="quiz-intro"></p>
                    <button id="quiz-start" class="quiz-primary-btn"></button>
                </div>

                <div id="quiz-game-screen" class="quiz-card" style="display:none;">
                    <div class="quiz-progress-bar">
                        <span id="quiz-progress-label"></span>
                        <span class="quiz-score-display">
                            <span id="quiz-score"></span>: <strong id="quiz-score-value">0</strong>
                        </span>
                    </div>

                    <p id="quiz-prompt" class="quiz-prompt"></p>

                    <div id="quiz-media" class="quiz-media"></div>

                    <div id="quiz-choices" class="quiz-choices"></div>

                    <div id="quiz-feedback" class="quiz-feedback"></div>

                    <div class="quiz-actions">
                        <button id="quiz-hint" class="quiz-secondary-btn" style="display:none;"></button>
                        <button id="quiz-next" class="quiz-primary-btn" style="display:none;"></button>
                    </div>
                </div>

                <div id="quiz-end-screen" class="quiz-card" style="display:none;">
                    <h1 id="quiz-round-end"></h1>
                    <p class="quiz-final-score-display">
                        <span id="quiz-final-score"></span>: <strong id="quiz-final-score-value">0</strong>
                    </p>
                    <button id="quiz-play-again" class="quiz-primary-btn"></button>
                </div>

            </section>
        </main>
    </div>

    <div id="footer-container"></div>

</body>

<script
    id="language-script"
    src="./scripts/language.js"
    dict="/quiz.json"
    keys="quiz-title,quiz-page-heading,quiz-intro,quiz-start,quiz-score,quiz-hint,quiz-next,quiz-round-end,quiz-final-score,quiz-play-again"
    galleryLength="0"
></script>

<script src="./scripts/sidebar.js"></script>
<script src="./scripts/search.js"></script>
<script src="./scripts/analytics.js"></script>
<script src="./scripts/footer.js"></script>
<script src="./scripts/share.js"></script>
<script src="./scripts/header.js" id="header-script"></script>
<script src="./scripts/quiz.js"></script>

</html>
